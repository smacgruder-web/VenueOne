NETWORK=development
PORT=3000
HOST=0.0.0.0

# Storage Configuration (using localStorage by default)
STORAGE_KEY=venue-ledger-v1
STORAGE_SHARED=true

# Google Cloud Storage (if using)
STORAGE_BUCKET=venue-ledger
STORAGE_PROJECT_ID=your-project-id
STORAGE_KEY_PATH=./credentials/key.json

# Server Configuration
VITE_SERVER_PORT=3000
VITE_SERVER_HOST=localhost

# Analytics (if enabling)
ANALYTICS_ENABLED=false
ANALYTICS_TRACKING_ID=UA-XXXXXXXXX-X

# Environment
NODE_ENV=development